# Equity Research Platform — Environment Variables
# Copy this file to .env and fill in your keys

# ── LLM Provider (choose one or leave auto to cascade) ────────────
LLM_PROVIDER=auto           # auto | openai | anthropic | groq | gemini | together | openrouter | ollama

# ── API Keys ───────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=               # Free tier available: console.groq.com
GOOGLE_API_KEY=
TOGETHER_API_KEY=
OPENROUTER_API_KEY=

# ── Financial Data APIs (optional — yfinance is free and default) ──
FMP_API_KEY=                # Financial Modeling Prep
ALPHA_VANTAGE_KEY=
POLYGON_API_KEY=

# ── Storage Paths ──────────────────────────────────────────────────
ER_REPORTS_DIR=             # Override default ~/Documents/Equity_Research_Reports

# ── Logging ────────────────────────────────────────────────────────
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR

# ── Ollama (local LLM, no API key required) ────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
